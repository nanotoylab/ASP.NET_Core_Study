@page
@model ASP.NET_Core_Study.Pages.ParentModel
@{
    ViewData["Title"] = "親画面";
}



@if (!string.IsNullOrEmpty(Model.ReturnedMessage))
{
    <div style="background-color: #d4edda; padding: 15px; margin-bottom: 20px; border-radius: 5px;">
        <strong>子画面からのメッセージ：</strong> @Model.ReturnedMessage
    </div>
}

<p>ここから子画面に移動して、データを入力してもらいます。</p>

<a asp-page="/Child" style="padding: 10px 20px; background-color: #007bff; color: white; text-decoration: none; border-radius: 5px;">
    子画面へ移動する
</a>
