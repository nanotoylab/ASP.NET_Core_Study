@page
@model ASP.NET_Core_Study.Pages.UserSearchModel
@{
    ViewData["Title"] = "ユーザー検索";
}


<h2 class="mt-4">社員検索システム</h2>

<form method="post" class="mt-3 mb-4">
    <label>名前または部署で検索：</label>
    <input type="text" asp-for="SearchKeyword" placeholder="例: 開発部" class="form-control d-inline-block w-25" />
    <button type="submit" class="btn btn-primary">検索</button>
</form>


<table class="table table-striped table-bordered">
    <thead class="table-dark">
        <tr>
            <th>社員ID</th>
            <th>氏名</th>
            <th>部署所属</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var user in Model.DisplayUsers)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.Name</td>
                <td>@user.Department</td>
            </tr>
        }

<p>検索結果：@Model.DisplayUsers.Count 件</p>

    </tbody>
</table>